{
    "name": "sinan-aydogan/tailadmin-laravel",
    "type": "project",
    "description": "It's a dashboard theme/UI-Starter Kit",
    "keywords": ["tailadmin", "laravel", "framework",  "dashboard", "starter kit", "vue", "admin panel", "admin theme", "admin framework"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.2",
        "inertiajs/inertia-laravel": "^0.6.8",
        "laravel-lang/json-fallback": "^2.0",
        "laravel-lang/locale-list": "^1.3",
        "laravel-lang/locales": "^2.5",
        "laravel-lang/native-country-names": "^1.3",
        "laravel-lang/native-currency-names": "^1.3",
        "laravel-lang/native-locale-names": "^2.2",
        "laravel/framework": "^10.10",
        "laravel/jetstream": "^4.2",
        "laravel/sanctum": "^3.3",
        "laravel/tinker": "^2.8",
        "spatie/laravel-permission": "^6.3.0",
        "tightenco/ziggy": "^1.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^v3.9.2",
        "fakerphp/faker": "^1.9.1",
        "laravel-lang/actions": "^1.4",
        "laravel-lang/attributes": "^2.9",
        "laravel-lang/common": "^6.1",
        "laravel-lang/http-statuses": "^3.8",
        "laravel-lang/lang": "^14.2",
        "laravel-lang/publisher": "^16.2",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.1",
        "roave/security-advisories": "dev-latest",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan lang:update"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
